# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required
DATABASE_URL=postgresql://ltq_user:strongpassword@localhost:5432/ltq

# Set to "true" when using a managed PG provider (Render, Railway, Supabase, Neon, etc.)
# that requires SSL with a self-signed certificate.
DATABASE_SSL=false

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# "production" enables Secure (HTTPS-only) cookies — required for any public deployment.
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. MUST be a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Changing this value invalidates ALL existing sessions.
JWT_SECRET=change-this-to-a-long-random-string

# ── Application URL ───────────────────────────────────────────────────────────
# Full public URL of this server — used in password-reset email links.
APP_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Only set this when the frontend is served from a DIFFERENT origin than the API.
# Leave blank when the frontend and API are served by the same Express process (default).
# CORS_ORIGIN=https://liberiatalentquest.com,https://www.liberiatalentquest.com

# ── File Uploads ─────────────────────────────────────────────────────────────
# Absolute path where uploaded photos/videos/documents are stored.
# Defaults to ~/ltq-uploads if not set. Must be OUTSIDE the web root.
# UPLOAD_DIR=/var/data/ltq-uploads

# ── Superuser (first-run seed) ────────────────────────────────────────────────
# Used only by "npm run db:init" when no superuser exists yet.
# Change the password immediately after first login — do NOT rely on these defaults.
SUPERUSER_NAME=Super Admin
SUPERUSER_EMAIL=admin@liberiatalentquest.local
SUPERUSER_PASSWORD=ChangeMe123!

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# If not configured, email content is printed to the console instead of sent.
# Credentials can also be stored in the DB via Superuser dashboard → Notification Channels
# (DB values take priority over .env values and update without a restart).
#
# Gmail App Password setup:
#   1. myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. myaccount.google.com → Security → App passwords → Generate
#   3. Paste the 16-character password into SMTP_PASS (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Liberia Talent Quest <yourname@gmail.com>

# ── WhatsApp (Meta Cloud API — free 1,000 conversations/month) ───────────────
# Recipients MUST have WhatsApp installed. Leave blank to disable.
# Can also be configured via Superuser dashboard → Notification Channels.
#
# Setup:
#   1. developers.facebook.com → Create App → Business → Add WhatsApp product
#   2. WhatsApp → API Setup: copy Phone Number ID + generate Permanent Token
#   3. Meta Business Manager → WhatsApp → Message Templates → Create template:
#        Name: ltq_notification | Category: UTILITY | Language: English
#        Body: Hello {{1}},\n\n{{2}}\n\n— Liberia Talent Quest
#   4. Submit for review (usually approved within a few hours for UTILITY templates)
WHATSAPP_TOKEN=your-permanent-token-here
WHATSAPP_PHONE_ID=your-phone-number-id-here
WHATSAPP_TEMPLATE=ltq_notification
WHATSAPP_TEMPLATE_LANG=en
