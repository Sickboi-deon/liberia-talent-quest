{
  "name": "liberia-talent-quest",
  "version": "1.0.0",
  "description": "Liberia Talent Quest — full-stack competition management platform",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "db:init": "node db/init.js",
    "db:migrate": "node db/migrate-categories.js && node db/migrate-contestant-numbers.js",
    "db:seed": "node db/seed-full.js",
    "db:seed:mock": "node db/seed-mock.js",
